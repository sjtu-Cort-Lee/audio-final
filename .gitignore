.cache/
.codex_deps/
data/
logs/

__pycache__/
*.py[cod]
*$py.class

.DS_Store

# Large final model weights are tracked by Git LFS. Keep intermediate
# training checkpoints and transient trainer artifacts out of normal commits.
checkpoints/**/checkpoint-*/
checkpoints/**/runs/
checkpoints/**/optimizer.pt
checkpoints/**/scheduler.pt
checkpoints/**/rng_state*.pth
checkpoints/**/scaler.pt

# LaTeX build byproducts. Keep source files, figures, and final PDFs.
*.aux
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.xdv

# Duplicate unpacked conference template backups are not needed for the repo.
templates/*_backup_*/
